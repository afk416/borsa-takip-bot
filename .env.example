# BotFather'dan alınan bot token'ı (zorunlu)
TELEGRAM_TOKEN=

# Gist persistence için GitHub Personal Access Token, "gist" scope'lu (önerilir)
# Yoksa kullanıcı verileri her redeploy'da sıfırlanır!
GITHUB_TOKEN=

# Admin'in (senin) Telegram chat ID'n — /admin ve /duyuru komutları için
ADMIN_CHAT_ID=

# Boş bırakılırsa bot herkese açık. Doldurursan yeni kullanıcılar bu kodu girmeden kullanamaz.
ACCESS_CODE=

# Alarm tarama sıklığı (saniye), default 300
CHECK_INTERVAL=300
